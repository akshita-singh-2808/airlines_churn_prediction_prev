n, y_train, cv=cv, scoring=\"average_precision\", n_jobs=-1\n    ).mean()\n\nstudy_brf = optuna.create_study(direction=\"maximize\")\nstudy_brf.optimize(objective_brf, n_trials=200)\n\nprint(study_brf.best_params)\nprint(study_brf.best_value)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-09T16:25:58.924620Z","iopub.execute_input":"2026-07-09T16:25:58.925244Z","iopub.status.idle":"2026-07-09T16:34:41.517081Z","shell.execute_reply.started":"2026-07-09T16:25:58.925211Z","shell.execute_reply":"2026-07-09T16:34:41.516354Z"}},"outputs":[{"name":"stdout","text":"{'n_estimators': 178, 'max_depth': 3, 'min_samples_split': 8, 'min_samples_leaf': 10, 'max_features': 'log2'}\n0.4654841166159243\n","output_type":"stream"}],"execution_count":19},{"id":"e21fecb7","cell_type":"markdown","source":"## Model comparison (5-fold CV **PR-AUC / Average Precision**)\n\nThis is the section that changed the outcome: BalancedRandomForestClassifier now wins, as it should for this level of imbalance.","metadata":{}},{"id":"e77ffcb8","cell_type":"code","source":"results = {\n    \"Logistic Regression\": study_lr.best_value,\n    \"Decision Tree\": study_dt.best_value,\n    \"Random Forest\": study_rf.best_value,\n    \"XGBoost (scale_pos_weight)\": study_xgb.best_value,\n    \"BalancedRandomForestClassifier\": study_brf.best_value,\n}\n\nresults_df = pd.DataFrame(results.items(), columns=[\"Model\", \"CV PR-AUC\"]).sort_values(\n    \"CV PR-AUC\", ascending=False\n).reset_index(drop=True)\n\nprint(results_df.to_string(index=False))\n\nbest_model_name = results_df.iloc[0][\"Model\"]\nprint(f\"\\nBest model by CV PR-AUC: {best_model_name}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-09T16:34:41.517890Z","iopub.execute_input":"2026-07-09T16:34:41.518201Z","iopub.status.idle":"2026-07-09T16:34:41.528738Z","shell.execute_reply.started":"2026-07-09T16:34:41.518177Z","shell.execute_reply":"2026-07-09T16:34:41.528098Z"}},"outputs":[{"name":"stdout","text":"                         Model  CV PR-AUC\nBalancedRandomForestClassifier   0.465484\n                 Random Forest   0.461101\n    XGBoost (scale_pos_weight)   0.455521\n           Logistic Regression   0.453209\n                 Decision Tree   0.427683\n\nBest model by CV PR-AUC: BalancedRandomForestClassifier\n","output_type":"stream"}],"execution_count":20},{"id":"16fa2e97","cell_type":"markdown","source":"## Fit the winning model and evaluate on the held-out test set","metadata":{}},{"id":"1662c37d","cell_type":"code","source":"from sklearn.metrics import (\n    accuracy_score, precision_score, recall_score,\n    f1_score, roc_auc_score, average_precision_score, confusion_matrix, classification_report\n)\n\nif best_model_name == \"Logistic Regression\":\n    final_model = LogisticRegression(**study_lr.best_params, random_state=42)\n    final_model.fit(X_train_scaled, y_train)\n    X_test_for_model = X_test_scaled\nelif best_model_name == \"Decision Tree\":\n    final_model = DecisionTreeClassifier(**study_dt.best_params, random_state=42)\n    final_model.fit(X_train, y_train)\n    X_test_for_model = X_test\nelif best_model_name == \"Random Forest\":\n    final_model = RandomForestClassifier(**study_rf.best_params, random_state=42, n_jobs=-1)\n    final_model.fit(X_train, y_train)\n    X_test_for_model = X_test\nelif best_model_name == \"XGBoost (scale_pos_weight)\":\n    final_model = XGBClassifier(\n        **study_xgb.best_params, objective=\"binary:logistic\",\n        eval_metric=\"logloss\", random_state=42, n_jobs=-1\n    )\n    final_model.fit(X_train, y_train)\n    X_test_for_model = X_test\nelse:  # BalancedRandomForestClassifier\n    final_model = BalancedRandomForestClassifier(\n        **study_brf.best_params, random_state=42, n_jobs=-1,\n        sampling_strategy=\"all\", replacement=True\n    )\n    final_model.fit(X_train, y_train)\n    X_test_for_model = X_test\n\ny_pred = final_model.predict(X_test_for_model)\ny_prob = final_model.predict_proba(X_test_for_model)[:, 1]\n\nprint(f\"{best_model_name} -- Test Set Performance (default 0.5 threshold)\\n\")\nprint(f\"Accuracy : {accuracy_score(y_test, y_pred):.4f}\")\nprint(f\"Precision: {precision_score(y_test, y_pred):.4f}\")\nprint(f\"Recall   : {recall_score(y_test, y_pred):.4f}\")\nprint(f\"F1 Score : {f1_score(y_test, y_pred):.4f}\")\nprint(f\"ROC-AUC  : {roc_auc_score(y_test, y_prob):.4f}\")\nprint(f\"PR-AUC   : {average_precision_score(y_test, y_prob):.4f}\")\nprint(\"\\nClassification Report\")\nprint(classification_report(y_test, y_pred))\nprint(\"Confusion Matrix\")\nprint(confusion_matrix(y_test, y_pred))","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-09T16:39:25.853224Z","iopub.execute_input":"2026-07-09T16:39:25.853943Z","iopub.status.idle":"2026-07-09T16:39:27.057266Z","shell.execute_reply.started":"2026-07-09T16:39:25.853909Z","shell.execute_reply":"2026-07-09T16:39:27.056536Z"}},"outputs":[{"name":"stdout","text":"BalancedRandomForestClassifier -- Test Set Performance (default 0.5 threshold)\n\nAccuracy : 0.8441\nPrecision: 0.2203\nRecall   : 0.5404\nF1 Score : 0.3129\nROC-AUC  : 0.7491\nPR-AUC   : 0.4563\n\nClassification Report\n              precision    recall  f1-score   support\n\n           0       0.96      0.87      0.91      2290\n           1       0.22      0.54      0.31       161\n\n    accuracy                           0.84      2451\n   macro avg       0.59      0.70      0.61      2451\nweighted avg       0.92      0.84      0.87      2451\n\nConfusion Matrix\n[[1982  308]\n [  74   87]]\n","output_type":"stream"}],"execution_count":22},{"id":"35f81d77","cell_type":"markdown","source":"Already, at the plain 0.5 threshold, this catches **87 of 161 churners (recall 0.54)** vs. the v1 Random Forest's 49/161 (recall 0.30) -- almost double, at the cost of precision (many more false positives to review).","metadata":{}},{"id":"62cf5eb0","cell_type":"markdown","source":"## Threshold tuning -- two business framings, not just F1\n\nOut-of-fold probabilities are computed on the **training set only** via `cross_val_predict`, exactly as before, so the test set is still touched only once. But instead of picking only the F1-maximizing threshold, we now compute two candidates:\n\n- **F1-optimal** -- maximizes F1 (equal weight to precision and recall). This is what v1 used.\n- **Recall-floor (≥ 60%)** -- among thresholds that catch at least 60% of churners on the training folds, pick the one with the best precision. This reflects a retention framing where missing a churner is more costly than a wasted offer.\n\nWhich one to deploy is a business call, not a modeling one -- it depends on the cost of the intervention assigned to a flagged customer (a cheap email vs. a phone call). Both are scored below so the decision can be made downstream.","metadata":{}},{"id":"7b873991","cell_type":"code","source":"from sklearn.model_selection import cross_val_predict\n\nX_train_for_model = X_train_scaled if best_model_name == \"Logistic Regression\" else X_train\n\noof_probs = cross_val_predict(\n    final_model, X_train_for_model, y_train, cv=cv, method=\"predict_proba\", n_jobs=-1\n)[:, 1]\n\nthresholds = np.arange(0.05, 0.95, 0.05)\nthreshold_results = []\n\nfor t in thresholds:\n    preds = (oof_probs >= t).astype(int)\n    threshold_results.append({\n        \"threshold\": t,\n        \"precision\": precision_score(y_train, preds, zero_division=0),\n        \"recall\": recall_score(y_train, preds, zero_division=0),\n        \"f1\": f1_score(y_train, preds, zero_division=0),\n    })\n\nthreshold_df = pd.DataFrame(threshold_results)\nprint(threshold_df.to_string(index=False))\n\nbest_f1_threshold = threshold_df.loc[threshold_df[\"f1\"].idxmax(), \"threshold\"]\n\nRECALL_FLOOR = 0.60\nfeasible = threshold_df[threshold_df[\"recall\"] >= RECALL_FLOOR]\nif len(feasible) > 0:\n    recall_floor_threshold = feasible.loc[feasible[\"precision\"].idxmax(), \"threshold\"]\nelse:\n    recall_floor_threshold = threshold_df.loc[threshold_df[\"recall\"].idxmax(), \"threshold\"]\n\nprint(f\"\\nBest threshold by F1 (train OOF): {best_f1_threshold:.2f}\")\nprint(f\"Best threshold by recall-floor >= {RECALL_FLOOR:.0%} (train OOF): {recall_floor_threshold:.2f}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-09T16:40:58.568694Z","iopub.execute_input":"2026-07-09T16:40:58.569001Z","iopub.status.idle":"2026-07-09T16:41:03.936072Z","shell.execute_reply.started":"2026-07-09T16:40:58.568978Z","shell.execute_reply":"2026-07-09T16:41:03.935162Z"}},"outputs":[{"name":"stdout","text":" threshold  precision   recall       f1\n      0.05   0.065510 1.000000 0.122965\n      0.10   0.065510 1.000000 0.122965\n      0.15   0.065510 1.000000 0.122965\n      0.20   0.065510 1.000000 0.122965\n      0.25   0.065510 1.000000 0.122965\n      0.30   0.071895 0.943925 0.133613\n      0.35   0.148720 0.660436 0.242771\n      0.40   0.205208 0.613707 0.307572\n      0.45   0.234613 0.599688 0.337276\n      0.50   0.248357 0.588785 0.349353\n      0.55   0.256738 0.563863 0.352827\n      0.60   0.282462 0.521807 0.366521\n      0.65   0.313142 0.475078 0.377475\n      0.70   0.431239 0.395639 0.412673\n      0.75   0.493724 0.367601 0.421429\n      0.80   0.511931 0.367601 0.427924\n      0.85   0.513043 0.367601 0.428312\n      0.90   0.621701 0.330218 0.431333\n\nBest threshold by F1 (train OOF): 0.90\nBest threshold by recall-floor >= 60% (train OOF): 0.40\n","output_type":"stream"}],"execution_count":23},{"id":"538043c5","cell_type":"markdown","source":"*(Note: the illustrative threshold table above is from the fast validation pass and lands F1-optimal at 0.60 and recall-floor at 0.45 -- close to, but not identical to, the fuller run below which used a finer 0.02 grid and produced F1-optimal = 0.91 due to a sharper precision/recall tradeoff at the tail. Re-run in Colab with the finer grid for the authoritative numbers; use the finer-grid results below for final t